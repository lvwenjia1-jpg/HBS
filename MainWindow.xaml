<Window x:Class="TestProject1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:domain="clr-namespace:TestProject1.Domain"
        xmlns:pages="clr-namespace:TestProject1.Controls.Pages"
        xmlns:sim="clr-namespace:TestProject1.Controls.Simulation"
        mc:Ignorable="d"
        Title="Wafer Bonding System Control"
        Width="1860"
        Height="1040"
        MinWidth="1560"
        MinHeight="920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#EAF1F7">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <LinearGradientBrush x:Key="ChromeBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#12345C" Offset="0" />
            <GradientStop Color="#2A638F" Offset="0.5" />
            <GradientStop Color="#12345C" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8FBFE" Offset="0" />
            <GradientStop Color="#E3ECF4" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#102640" Offset="0" />
            <GradientStop Color="#1A3C60" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="FrameBrush" Color="#C7D5E2" />
        <SolidColorBrush x:Key="SubTextBrush" Color="#627B95" />
        <SolidColorBrush x:Key="HmiTabBarBrush" Color="#DCE7F1" />
        <SolidColorBrush x:Key="HmiTabBorderBrush" Color="#AEC1D4" />
        <SolidColorBrush x:Key="HmiTabIdleBrush" Color="#E9F0F6" />
        <SolidColorBrush x:Key="HmiTabHoverBrush" Color="#D6E4F0" />
        <SolidColorBrush x:Key="HmiTabActiveBrush" Color="#214C74" />
        <SolidColorBrush x:Key="HmiTabActiveTextBrush" Color="#F8FBFE" />
        <SolidColorBrush x:Key="HmiTabLampIdleBrush" Color="#90A4B8" />
        <SolidColorBrush x:Key="HmiTabLampHoverBrush" Color="#59B7E8" />
        <SolidColorBrush x:Key="HmiTabLampActiveBrush" Color="#7BE0C6" />
        <SolidColorBrush x:Key="HmiTabIconIdleBrush" Color="#D9E4EE" />
        <SolidColorBrush x:Key="HmiTabIconHoverBrush" Color="#C6D9EA" />
        <SolidColorBrush x:Key="HmiTabIconActiveBrush" Color="#2F628E" />
        <SolidColorBrush x:Key="HmiTabChevronBrush" Color="#6A839D" />
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#193450" />
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#366C97" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2F6088" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#99AABD" />
                    <Setter Property="Foreground" Value="#EEF3F8" />
                    <Setter Property="Opacity" Value="0.78" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FlowStageBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#EAF2FA" />
            <Setter Property="BorderBrush" Value="#C5D6E7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,0,10,8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#D7F1E8" />
                    <Setter Property="BorderBrush" Value="#7BBEAA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#23496D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D648C" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="EmergencyButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#B72E2E" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Width" Value="158" />
            <Setter Property="Height" Value="46" />
        </Style>
        <Style x:Key="TablessTabControlStyle" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HmiSubTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#18314C" />
            <Setter Property="Background" Value="{StaticResource HmiTabIdleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource HmiTabBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="196" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse x:Name="StatusLamp"
                                         Width="10"
                                         Height="10"
                                         Margin="2,0,12,0"
                                         VerticalAlignment="Center"
                                         Fill="{StaticResource HmiTabLampIdleBrush}" />

                                <Border x:Name="IconPlate"
                                        Grid.Column="1"
                                        Width="34"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Background="{StaticResource HmiTabIconIdleBrush}"
                                        BorderBrush="#B6C9DB"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#234563" />
                                </Border>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{TemplateBinding Foreground}" />
                                    <TextBlock x:Name="NavCaption"
                                               Margin="0,2,0,0"
                                               Text="Panel Navigation"
                                               FontSize="10"
                                               Foreground="#6B829B" />
                                </StackPanel>

                                <TextBlock x:Name="Chevron"
                                           Grid.Column="3"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource HmiTabChevronBrush}"
                                           Text=">" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource HmiTabHoverBrush}" />
                                <Setter TargetName="StatusLamp" Property="Fill" Value="{StaticResource HmiTabLampHoverBrush}" />
                                <Setter TargetName="IconPlate" Property="Background" Value="{StaticResource HmiTabIconHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource HmiTabActiveTextBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource HmiTabActiveBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HmiTabActiveBrush}" />
                                <Setter TargetName="StatusLamp" Property="Fill" Value="{StaticResource HmiTabLampActiveBrush}" />
                                <Setter TargetName="IconPlate" Property="Background" Value="{StaticResource HmiTabIconActiveBrush}" />
                                <Setter TargetName="IconPlate" Property="BorderBrush" Value="#74B6E1" />
                                <Setter TargetName="NavCaption" Property="Foreground" Value="#BED8F0" />
                                <Setter TargetName="Chevron" Property="Foreground" Value="#DCEAF8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HmiSubTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Margin="0,0,0,14"
                                    Background="{StaticResource HmiTabBarBrush}"
                                    BorderBrush="{StaticResource HmiTabBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="14,12">
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Left"
                                            Margin="0,0,16,0"
                                            Padding="14,8"
                                            Background="#EFF5FA"
                                            BorderBrush="#C4D3E1"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Text="SUB NAV"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="#2F4F6D" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="HMI Console"
                                                       FontSize="11"
                                                       Foreground="#6E849B" />
                                        </StackPanel>
                                    </Border>
                                    <TabPanel IsItemsHost="True"
                                              Background="Transparent"
                                              KeyboardNavigation.TabIndex="1" />
                                </DockPanel>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="0" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate DataType="{x:Type domain:WaferSlotState}">
            <Border Width="54" Height="52" Margin="0,0,6,6" CornerRadius="8" Background="{Binding FillBrush}" BorderBrush="#E6EEF8" BorderThickness="1" ToolTip="{Binding DetailText}">
                <TextBlock Text="{Binding DisplayText}" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" CornerRadius="24" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#244B73" CornerRadius="999" Padding="10,4">
                            <TextBlock Text="ARMS" Foreground="White" FontSize="12" FontWeight="Bold" />
                        </Border>
                        <TextBlock Margin="12,0,0,0" Text="{Binding Texts[system_title]}" Foreground="White" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" Text="{Binding LineIdentityText}" Foreground="#D7E6F8" FontSize="13" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,14,0,0">
                        <Border Margin="0,0,12,12" Background="#214769" CornerRadius="16" Padding="12"><StackPanel Width="220"><TextBlock Text="{Binding Texts[status]}" Foreground="#B8D6F2" FontSize="12" /><TextBlock Margin="0,4,0,0" Text="{Binding OperationStatusText}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" /></StackPanel></Border>
                        <Border Margin="0,0,12,12" Background="#214769" CornerRadius="16" Padding="12"><StackPanel Width="220"><TextBlock Text="{Binding Texts[current_recipe]}" Foreground="#B8D6F2" FontSize="12" /><TextBlock Margin="0,4,0,0" Text="{Binding ActiveRecipe.Name}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" /></StackPanel></Border>
                        <Border Margin="0,0,12,12" Background="#214769" CornerRadius="16" Padding="12"><StackPanel Width="240"><TextBlock Text="{Binding Texts[wafer_focus]}" Foreground="#B8D6F2" FontSize="12" /><TextBlock Margin="0,4,0,0" Text="{Binding FocusWaferText}" Foreground="White" FontSize="17" FontWeight="Bold" TextWrapping="Wrap" /></StackPanel></Border>
                    </WrapPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Width="132" Height="40" Margin="0,0,16,0" Background="#E8EEF6" Foreground="#17314D" BorderThickness="0" Command="{Binding ToggleLanguageCommand}" Content="{Binding CurrentLanguageText}" />
                    <TextBlock Margin="0,0,18,0" Text="{Binding ClockText}" Foreground="White" FontSize="20" VerticalAlignment="Center" />
                    <Button Style="{StaticResource EmergencyButtonStyle}" Command="{Binding EmergencyStopCommand}" Content="{Binding Texts[trigger_estop]}" />
                </StackPanel>
            </Grid>
        </Border>


        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="248" Background="{StaticResource SidebarBrush}" CornerRadius="24" Padding="18" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Workspace / 工作区" Foreground="White" FontSize="22" FontWeight="Bold" /><TextBlock Margin="0,6,0,0" Text="{Binding LineIdentityText}" Foreground="#B9D5F1" TextWrapping="Wrap" /></StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,22,0,0">
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowOverviewCommand}" Content="{Binding Texts[overview]}" />
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowProcessCommand}" Content="{Binding Texts[process]}" />
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowRecipeCommand}" Content="{Binding Texts[recipe]}" />
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowAlarmCommand}" Content="{Binding Texts[alarms]}" />
                        <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowSettingsCommand}" Content="{Binding Texts[settings]}" />
                    </StackPanel>
                    <UniformGrid Grid.Row="2" Columns="2">
                        <Border Margin="0,0,8,8" Background="#22466A" CornerRadius="16" Padding="12"><StackPanel><TextBlock Text="{Binding OnlineModules}" Foreground="White" FontSize="22" FontWeight="Bold" /><TextBlock Text="{Binding Texts[online_modules]}" Foreground="#B8D6F2" FontSize="12" TextWrapping="Wrap" /></StackPanel></Border>
                        <Border Margin="8,0,0,8" Background="#22466A" CornerRadius="16" Padding="12"><StackPanel><TextBlock Text="{Binding BusyModules}" Foreground="White" FontSize="22" FontWeight="Bold" /><TextBlock Text="{Binding Texts[busy_modules]}" Foreground="#B8D6F2" FontSize="12" TextWrapping="Wrap" /></StackPanel></Border>
                        <Border Margin="0,8,8,0" Background="#22466A" CornerRadius="16" Padding="12"><StackPanel><TextBlock Text="{Binding ActiveAlarmCount}" Foreground="White" FontSize="22" FontWeight="Bold" /><TextBlock Text="{Binding Texts[alarms]}" Foreground="#B8D6F2" FontSize="12" TextWrapping="Wrap" /></StackPanel></Border>
                        <Border Margin="8,8,0,0" Background="#22466A" CornerRadius="16" Padding="12"><StackPanel><TextBlock Text="{Binding RunningJobs}" Foreground="White" FontSize="22" FontWeight="Bold" /><TextBlock Text="{Binding Texts[active_jobs]}" Foreground="#B8D6F2" FontSize="12" TextWrapping="Wrap" /></StackPanel></Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" MinWidth="0" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="68" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" CornerRadius="24,24,0,0" Padding="20,0">
                        <DockPanel>
                            <StackPanel><TextBlock Text="{Binding CurrentSectionTitle}" Foreground="White" FontSize="24" FontWeight="Bold" /><TextBlock Text="{Binding StatusBanner}" Foreground="#D0E0F1" FontSize="12" /></StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#2C5078" CornerRadius="999" Padding="12,6" Margin="0,0,10,0"><TextBlock Text="{Binding OperationStatusText}" Foreground="White" FontWeight="Bold" /></Border>
                                <Border Background="#2C5078" CornerRadius="999" Padding="12,6"><TextBlock Text="{Binding FocusWaferText}" Foreground="#DCEBFA" FontWeight="SemiBold" /></Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TabControl Grid.Row="1" Style="{StaticResource TablessTabControlStyle}" SelectedIndex="{Binding SelectedSectionIndex}" BorderThickness="0" Background="Transparent">
                        <TabItem>
                            <TabControl Margin="20" Style="{StaticResource HmiSubTabControlStyle}">
                                <TabItem Header="Simulation" Tag="SIM" Style="{StaticResource HmiSubTabItemStyle}" DataContext="{Binding SimulationPage}">
                                    <Grid Margin="0" MinHeight="720">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Margin="0,0,0,14"
                                                Background="#EAF2FA"
                                                BorderBrush="#C5D6E7"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="12,10">
                                            <DockPanel>
                                                <WrapPanel>
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ConnectAllCommand}" Content="{Binding Texts[connect_all]}" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding HomeAllCommand}" Content="{Binding Texts[home_all]}" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding OpenDoorsCommand}" Content="{Binding Texts[open_doors]}" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CloseDoorsCommand}" Content="{Binding Texts[close_doors]}" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RunRecipeCommand}" Content="{Binding Texts[run_recipe]}" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RunSchedulerCycleCommand}" Content="Scheduler Cycle / 调度循环" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ToggleVirtualLineCommand}" Content="{Binding VirtualLineActionText}" />
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ResetCommand}" Content="{Binding Texts[reset_sim]}" />
                                                </WrapPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Click="OpenSimulationWindow_Click"
                                                        Content="Open Window / 独立窗口" />
                                            </DockPanel>
                                        </Border>

                                        <Border Grid.Row="1"
                                                Margin="0,0,0,14"
                                                Background="#F3F8FD"
                                                BorderBrush="#C5D6E7"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <WrapPanel>
                                                    <Border Style="{StaticResource FlowStageBadgeStyle}" Tag="{Binding IsConnectStageReady}">
                                                        <TextBlock Text="1) Connect Ready" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Style="{StaticResource FlowStageBadgeStyle}" Tag="{Binding IsHomeStageReady}">
                                                        <TextBlock Text="2) Home Ready" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Style="{StaticResource FlowStageBadgeStyle}" Tag="{Binding IsDoorStageReady}">
                                                        <TextBlock Text="3) Door Interlock Ready" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Style="{StaticResource FlowStageBadgeStyle}" Tag="{Binding IsRunStageReady}">
                                                        <TextBlock Text="4) Run Ready" FontWeight="SemiBold" />
                                                    </Border>
                                                </WrapPanel>
                                                <DockPanel Grid.Row="1" Margin="2,2,0,0" LastChildFill="False">
                                                    <TextBlock Text="{Binding OperationFlowSummaryText}"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                    <WrapPanel DockPanel.Dock="Right">
                                                        <Border Margin="0,0,8,0" Background="#EAF2FA" CornerRadius="10" Padding="10,5">
                                                            <TextBlock Text="{Binding LoadedWafers, StringFormat=Loaded {0}}" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border Margin="0,0,8,0" Background="#EAF2FA" CornerRadius="10" Padding="10,5">
                                                            <TextBlock Text="{Binding MovingWaferCount, StringFormat=Moving {0}}" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border Margin="0,0,8,0" Background="#EAF2FA" CornerRadius="10" Padding="10,5">
                                                            <TextBlock Text="{Binding RunningJobs, StringFormat=Jobs {0}}" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border Background="#EAF2FA" CornerRadius="10" Padding="10,5">
                                                            <TextBlock Text="{Binding ActiveAlarmCount, StringFormat=Alarm {0}}" FontWeight="SemiBold" />
                                                        </Border>
                                                    </WrapPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>

                                        <pages:SimulationWorkspacePanel Grid.Row="2" SurfaceMinHeight="620" />
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Overview" Tag="OVR" Style="{StaticResource HmiSubTabItemStyle}" DataContext="{Binding OverviewPage}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <WrapPanel Margin="0">
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14" Width="320">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource SubTextBrush}" Text="{Binding Texts[throughput]}" />
                                                    <TextBlock Margin="0,6,0,0" FontSize="22" FontWeight="Bold" Text="{Binding ThroughputText}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="#527092" Text="{Binding ProcessRouteText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14" Width="320">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource SubTextBrush}" Text="Factory Snapshot / 产线快照" />
                                                    <TextBlock Margin="0,6,0,0" FontSize="21" FontWeight="Bold" Text="{Binding ModuleSummaryText}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="#527092" Text="{Binding LayoutSummary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14" Width="320">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource SubTextBrush}" Text="Transfer / 搬运" />
                                                    <TextBlock Margin="0,6,0,0" FontSize="17" FontWeight="Bold" Text="{Binding CurrentTransferSummary}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="#527092" Text="{Binding CurrentTransferDetail}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14" Width="320">
                                                <StackPanel>
