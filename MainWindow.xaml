                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Texts[alarm_catalog]}" FontSize="20" FontWeight="Bold" />
                                                <DataGrid Grid.Row="1" Margin="0,14,0,0" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" ItemsSource="{Binding AlarmCatalog}" IsReadOnly="True">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="90" />
                                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                                        <DataGridTextColumn Header="Recovery" Binding="{Binding RecoveryHint}" Width="*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    </WrapPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem DataContext="{Binding SettingsPage}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Texts[settings]}" FontSize="22" FontWeight="Bold" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding SettingsHintText}" Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1">
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding OpenDoorsCommand}" Content="{Binding Texts[open_doors]}" />
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CloseDoorsCommand}" Content="{Binding Texts[close_doors]}" />
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding InjectAlarmCommand}" Content="{Binding Texts[inject_alarm]}" />
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ResetEmergencyStopCommand}" Content="{Binding Texts[reset_estop]}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <WrapPanel Grid.Row="1">
                                        <Grid Width="760" Margin="0,0,16,16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Texts[parameter_settings]}" FontSize="20" FontWeight="Bold" />
                                                    <DataGrid Grid.Row="1" Margin="0,14,0,0" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" ItemsSource="{Binding Parameters}" IsReadOnly="True">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120" />
                                                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" />
                                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="150" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Texts[gem_state]}" FontSize="20" FontWeight="Bold" />
                                                    <UniformGrid Margin="0,14,0,0" Columns="2">
                                                        <Border Margin="0,0,10,0" Background="#EEF5FC" CornerRadius="16" Padding="14"><StackPanel><TextBlock Text="{Binding GemCommunicationState}" FontSize="18" FontWeight="Bold" /><TextBlock Margin="0,4,0,0" Text="Communication" Foreground="{StaticResource SubTextBrush}" /></StackPanel></Border>
                                                        <Border Background="#EEF5FC" CornerRadius="16" Padding="14"><StackPanel><TextBlock Text="{Binding GemControlState}" FontSize="18" FontWeight="Bold" /><TextBlock Margin="0,4,0,0" Text="Control" Foreground="{StaticResource SubTextBrush}" /></StackPanel></Border>
                                                    </UniformGrid>
                                                    <ListBox Margin="0,14,0,0" BorderThickness="0" Background="Transparent" ItemsSource="{Binding GemMessages}">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type domain:GemMessageRecord}">
                                                                <Border Margin="0,0,0,8" Padding="12" Background="#EEF5FC" CornerRadius="14">
                                                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Width="520" Margin="0,0,0,16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Texts[module_summary]}" FontSize="20" FontWeight="Bold" />
                                                    <TextBlock Margin="0,12,0,0" Text="{Binding ModuleSummaryText}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,8,0,0" Text="{Binding LineIdentityText}" Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,8,0,0" Text="{Binding StatusBanner}" Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Texts[robot_motion]}" FontSize="20" FontWeight="Bold" />
                                                    <ItemsControl Grid.Row="1" Margin="0,14,0,0" ItemsSource="{Binding Robots}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type domain:RobotRuntimeState}">
                                                                <Border Margin="0,0,0,10" Padding="12" Background="#EEF5FC" CornerRadius="14">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                                                                            <TextBlock Margin="0,4,0,0" Text="{Binding CapabilityText}" Foreground="{StaticResource SubTextBrush}" />
                                                                            <TextBlock Margin="0,2,0,0" Text="{Binding MotionProfileText}" Foreground="{StaticResource SubTextBrush}" />
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="1" Text="{Binding HeldWaferText}" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Texts[process_stage]}" FontSize="20" FontWeight="Bold" />
                                                    <ItemsControl Grid.Row="1" Margin="0,14,0,0" ItemsSource="{Binding Chambers}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type domain:ChamberRuntimeState}">
                                                                <Border Margin="0,0,0,10" Padding="12" Background="#EEF5FC" CornerRadius="14">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                                                                            <TextBlock Margin="0,4,0,0" Text="{Binding PurposeText}" Foreground="{StaticResource SubTextBrush}" />
                                                                            <TextBlock Margin="0,2,0,0" Text="{Binding OccupiedText}" Foreground="{StaticResource SubTextBrush}" />
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Column="1" Text="{Binding DoorText}" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </WrapPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
